# Primary — Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Fallback 1 — Get a free API key at https://aistudio.google.com/apikey
PRIMARY_GEMINI_API_KEY=your_gemini_api_key_here

# Fallback 2 — Get one at https://openrouter.ai/keys
SECONDARY_OPENROUTER_API_KEY=your_openrouter_key_here

# GitHub OAuth — Create an OAuth App at https://github.com/settings/developers
# Set the callback URL to: http://localhost:3000/api/auth/github/callback (dev)
#                     or: https://your-domain.com/api/auth/github/callback (prod)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Session encryption secret — generate with: openssl rand -base64 32
SESSION_SECRET=your_session_secret_here
